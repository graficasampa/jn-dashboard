# GA4 — Service Account JSON (string completa em uma linha)
# Gerar em: console.cloud.google.com → APIs & Services → Credentials → Service Account
# Dar permissão de "Viewer" na propriedade GA4 (492019962) para o service account
GA4_CREDENTIALS={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...","client_email":"...@...iam.gserviceaccount.com","token_uri":"https://oauth2.googleapis.com/token"}
GA4_PROPERTY_ID=492019962

# Meta Ads — Token de longa duração (expira em ~60 dias, renovar manualmente)
# Gerar em: developers.facebook.com → Tools → Graph API Explorer
# Permissões necessárias: ads_read, read_insights
META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
META_ACCOUNT_ID=act_489839481099112
